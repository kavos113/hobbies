{
  "name": "md-editor",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/main.js",
  "type": "commonjs",
  "scripts": {
    "build": "pnpm run build:main && pnpm run build:preload && pnpm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "clean": "rimraf out dist",
    "dev": "concurrently -k \"pnpm run dev:renderer\" \"pnpm run dev:main\"",
    "dev:main": "wait-on tcp:5173 && pnpm run build:main && pnpm run build:preload && cross-env NODE_ENV=development electron .",
    "dev:renderer": "vite --port 5173 --strictPort",
    "dev:main-alt": "wait-on tcp:5174 && pnpm run build:main && pnpm run build:preload && cross-env NODE_ENV=development electron .",
    "dev:renderer-alt": "vite --port 5174 --strictPort",
    "dev:alt": "concurrently -k \"pnpm run dev:renderer-alt\" \"pnpm run dev:main-alt\"",
    "start": "pnpm run build && cross-env NODE_ENV=production electron .",
    "dist": "pnpm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.mdeditor.desktop",
    "productName": "MD Editor",
    "files": [
      "dist/**/*",
      "out/main/**/*",
      "out/preload/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@uiw/react-codemirror": "^4.25.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.2",
    "electron": "^35.1.0",
    "electron-builder": "^25.1.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.1",
    "wait-on": "^8.0.4"
  }
}
